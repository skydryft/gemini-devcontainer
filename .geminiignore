# .geminiignore — Controls which files Gemini CLI scans for context.
# Critical for devcontainer performance: .git/ alone saves ~70% startup time.

# Version control internals
.git/

# Dependencies (scanned via Gemfile, not file contents)
node_modules/
vendor/bundle/

# Rails temporary files and caches
tmp/
log/
storage/

# Build outputs and compiled assets
dist/
build/
public/assets/
public/packs/

# Caches and coverage
.cache/
coverage/
.nyc_output/

# Lock files (large, low context value)
*.lock

# Logs
*.log

# Database files
db/*.sqlite3

# Binary and media files
*.png
*.jpg
*.jpeg
*.gif
*.svg
*.ico
*.mp4
*.webm
*.woff
*.woff2
*.ttf
*.eot

# IDE and tool configuration
.vscode/
.idea/
__pycache__/
*.pyc
